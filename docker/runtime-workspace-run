#!/command/with-contenv sh
set -eu

cd /opt/hermes-workspace

export NODE_ENV="${NODE_ENV:-production}"
export PORT="${PORT:-3000}"
export HOST="${HOST:-0.0.0.0}"
export HERMES_API_URL="${HERMES_API_URL:-http://127.0.0.1:8642}"
export HERMES_DASHBOARD_URL="${HERMES_DASHBOARD_URL:-http://127.0.0.1:9119}"
export HERMES_WORKSPACE_DIR="${HERMES_WORKSPACE_DIR:-/workspace}"

if [ "$(id -u)" = "0" ]; then
  if [ -n "${HERMES_GID:-}" ]; then
    case "$HERMES_GID" in
      *[!0-9]*)
        echo "invalid HERMES_GID=$HERMES_GID" >&2
        exit 111
        ;;
      *)
        current_gid="$(id -g hermes)"
        if [ "$HERMES_GID" != "$current_gid" ]; then
          groupmod -o -g "$HERMES_GID" hermes 2>/dev/null || true
        fi
        ;;
    esac
  fi

  if [ -n "${HERMES_UID:-}" ]; then
    case "$HERMES_UID" in
      *[!0-9]*)
        echo "invalid HERMES_UID=$HERMES_UID" >&2
        exit 111
        ;;
      *)
        current_uid="$(id -u hermes)"
        if [ "$HERMES_UID" != "$current_uid" ]; then
          usermod -o -u "$HERMES_UID" hermes
        fi
        ;;
    esac
  fi
fi

if [ "$(id -u)" = "0" ] && [ -n "${OPENCLAW_NAS_DATA_GID:-}" ]; then
  case "$OPENCLAW_NAS_DATA_GID" in
    *[!0-9]*)
      echo "ignoring non-numeric OPENCLAW_NAS_DATA_GID=$OPENCLAW_NAS_DATA_GID" >&2
      ;;
    *)
      data_group="$(getent group "$OPENCLAW_NAS_DATA_GID" | awk -F: 'NR == 1 {print $1}' || true)"
      if [ -z "$data_group" ]; then
        data_group="openclaw-nas-data"
        if getent group "$data_group" >/dev/null 2>&1; then
          data_group="openclaw-nas-$OPENCLAW_NAS_DATA_GID"
        fi
        groupadd -g "$OPENCLAW_NAS_DATA_GID" "$data_group" 2>/dev/null || true
        data_group="$(getent group "$OPENCLAW_NAS_DATA_GID" | awk -F: 'NR == 1 {print $1}' || true)"
      fi
      if [ -n "$data_group" ]; then
        usermod -a -G "$data_group" hermes 2>/dev/null || true
      fi
      ;;
  esac
fi

uid="$(id -u hermes)"
gid="$(id -g hermes)"
if [ "$uid:$gid" = "10000:10000" ] && [ "${ALLOW_HERMES_DEFAULT_UID_GID:-0}" != "1" ]; then
  echo "refusing to start workspace before hermes uid/gid initialization: $uid:$gid" >&2
  exit 111
fi

if [ -n "${HERMES_UID:-}" ] && [ "$uid" != "$HERMES_UID" ]; then
  echo "refusing to start workspace with wrong hermes uid: actual=$uid expected=$HERMES_UID" >&2
  exit 111
fi

if [ -n "${HERMES_GID:-}" ] && [ "$gid" != "$HERMES_GID" ]; then
  echo "refusing to start workspace with wrong hermes gid: actual=$gid expected=$HERMES_GID" >&2
  exit 111
fi

if [ -n "${OPENCLAW_NAS_DATA_GID:-}" ]; then
  case "$OPENCLAW_NAS_DATA_GID" in
    *[!0-9]*) ;;
    *)
      if ! id -G hermes | tr ' ' '\n' | grep -Fx "$OPENCLAW_NAS_DATA_GID" >/dev/null; then
        echo "refusing to start workspace without NAS data group membership: gid=$OPENCLAW_NAS_DATA_GID" >&2
        exit 111
      fi
      ;;
  esac
fi

exec s6-setuidgid hermes node --max-old-space-size="${NODE_MAX_OLD_SPACE_SIZE:-2048}" server-entry.js
